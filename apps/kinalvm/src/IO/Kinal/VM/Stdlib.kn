[VmBuiltin(22, "IO.Type.string.ToChars")]
Static Unsafe Function void BuiltinStringToChars(Context.ExecutionContext ctx, int dst, int a0, int a1, int a2, int a3)
{
    char[] chars = ctx.GetString(a0).ToChars();
    int handle = ctx.NewArray(chars.Length(), [int](Bytecode.ValueKind.Char));
    For (int i = 0; i < chars.Length(); i = i + 1)
    {
        ctx.ArraySetValue(handle, i, Context.VMValue.FromChar(chars.Index(i)));
    }
    ctx.CurrentFrame().ImportValue(dst, Context.VMValue.FromArray(handle));
}

