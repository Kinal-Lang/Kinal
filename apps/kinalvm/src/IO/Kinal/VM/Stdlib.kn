Unit IO.Kinal.VM.Stdlib;

Get Bytecode By IO.Kinal.VM.Bytecode;
Get Console By IO.Console;
Get File By IO.File;
Get Meta By IO.Meta;
Get Time By IO.Time;
Get IO.Type.string;
Get Context By IO.Kinal.VM.Context;

Meta VmBuiltin(int id, string name)
{
    On @function;
    Keep @runtime;
}

Static Function bool AnyEquals(Context.ExecutionContext ctx, int a, int b)
{
    Context.FunctionFrame frame = ctx.CurrentFrame();

    If (frame.Kinds[a] != frame.Kinds[b])
    {
        Return false;
    }

    Return Switch(frame.Kinds[a])
    {
        Case([int](Bytecode.ValueKind.Null))   { true }
        Case([int](Bytecode.ValueKind.Int))    { frame.IntRegisters[a] == frame.IntRegisters[b] }
        Case([int](Bytecode.ValueKind.Float))  { frame.FloatRegisters[a] == frame.FloatRegisters[b] }
        Case([int](Bytecode.ValueKind.Bool))   { frame.BoolRegisters[a] == frame.BoolRegisters[b] }
        Case([int](Bytecode.ValueKind.String)) { frame.StringRegisters[a] == frame.StringRegisters[b] }
        Case([int](Bytecode.ValueKind.Char))   { frame.IntRegisters[a] == frame.IntRegisters[b] }
        Case([int](Bytecode.ValueKind.Array))  { frame.IntRegisters[a] == frame.IntRegisters[b] }
        Case([int](Bytecode.ValueKind.Object)) { frame.IntRegisters[a] == frame.IntRegisters[b] }
        Case(default)                   { false }
    };
}

Static Function string AnyTypeName(Context.ExecutionContext ctx, int reg)
{
    Context.FunctionFrame frame = ctx.CurrentFrame();

    Return Switch(frame.Kinds[reg])
    {
        Case([int](Bytecode.ValueKind.Null))   { "null" }
        Case([int](Bytecode.ValueKind.Int))    { "int" }
        Case([int](Bytecode.ValueKind.Float))  { "float" }
        Case([int](Bytecode.ValueKind.Bool))   { "bool" }
        Case([int](Bytecode.ValueKind.String)) { "string" }
        Case([int](Bytecode.ValueKind.Char))   { "char" }
        Case([int](Bytecode.ValueKind.Array))  { "array" }
        Case([int](Bytecode.ValueKind.Object)) { ctx.Stringify(reg) }
        Case([int](Bytecode.ValueKind.Pointer)) { "pointer" }
        Case(default)                   { "unknown" }
    };
}

Static Function bool TextContains(string text, string needle)
{
    char[] haystack = text.ToChars();
    char[] pattern = needle.ToChars();
    int hayLength = haystack.Length();
    int patternLength = pattern.Length();

    If (patternLength <= 0)
    {
        Return true;
    }
    If (hayLength < patternLength)
    {
        Return false;
    }

    For (int i = 0; i <= hayLength - patternLength; i = i + 1)
    {
        bool matched = true;
        For (int j = 0; j < patternLength; j = j + 1)
        {
            If (haystack.Index(i + j) != pattern.Index(j))
            {
                matched = false;
                Break;
            }
        }
        If (matched)
        {
            Return true;
        }
    }

    Return false;
}

Public Class StdlibRegistry
{
    Public IO.Type.Object.Function[] Handlers;
    Public bool[] Present;
    Public string[] Names;

    Public Constructor()
    {
        This.Handlers = {};
        This.Present = {};
        This.Names = {};

        IO.Type.Object.Function empty = null;
        For (int i = 0; i < 256; i = i + 1)
        {
            This.Handlers = This.Handlers.Add(empty);
            This.Present = This.Present.Add(false);
            This.Names = This.Names.Add("");
        }
    }

    Public Unsafe Static Function StdlibRegistry BuildDefault()
    {
        StdlibRegistry registry = New StdlibRegistry();
        list owners = Meta.Query("VmBuiltin");
        For (int i = 0; i < owners.Count(); i = i + 1)
        {
            dict item = Meta.Find([string](owners.Fetch(i)), "VmBuiltin");
            registry.RegisterMeta(item);
        }
        Return registry;
    }

    Private Unsafe Function void RegisterMeta(dict item)
    {
        int id = [int](item.Fetch("arg.id"));
        byte* owner = [byte*](item.Fetch("owner_ptr"));
        IO.Type.Object.Function fn = [Object.Function](owner);

        If (id < 0 || id >= This.Handlers.Length())
        {
            Throw "VmBuiltin id out of range: " + [string](id);
        }

        This.Handlers[id] = fn;
        This.Present[id] = true;
        This.Names[id] = [string](item.Fetch("arg.name"));
    }

    Public Function void Invoke(Context.ExecutionContext ctx, int builtinId, int dst, int a0, int a1, int a2, int a3)
    {
        If (builtinId < 0 || builtinId >= This.Handlers.Length() || !This.Present[builtinId])
        {
            Throw "Unregistered builtin: " + [string](builtinId);
        }

        IO.Type.Object.Function fn = This.Handlers[builtinId];
        fn(ctx, dst, a0, a1, a2, a3);
    }
}

