Unit IO.Kinal.VM.VM;

Get Bytecode By IO.Kinal.VM.Bytecode;
Get Context By IO.Kinal.VM.Context;
Get Stdlib By IO.Kinal.VM.Stdlib;
Get Console By IO.Console;

Public Class VirtualMachine
{
    Private Stdlib.StdlibRegistry Registry;

    Public Constructor(Stdlib.StdlibRegistry registry)
    {
        This.Registry = registry;
    }

    Public Unsafe Function int Execute(Bytecode.Program program)
    {
        Context.ExecutionContext ctx = New Context.ExecutionContext(program);
        int[] dispatchTargets = {};
        Stdlib.StdlibRegistry registry = This.Registry;

        ctx.PushEntry(program.EntryFunction);

        Unsafe Block Dispatch
        </
            Record LoopStart
            If (ctx.Halted || ctx.FrameCount <= 0)
            {
                Jump Halt;
            }

            Context.FunctionFrame frame = ctx.CurrentFrame();
            byte[] code = frame.FnInfo.Code;
            int codeLength = code.Length();

            If (frame.Pc < 0 || frame.Pc >= codeLength)
            {
                Throw "Instruction pointer out of range";
            }

            int op = [int](code[frame.Pc]);
            If (op < 0 || op >= dispatchTargets.Length())
            {
                Throw "Unknown KNC opcode: " + [string](op);
            }

            Jump dispatchTargets[op];

            Record OpLoadInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    program.IntConstants[Bytecode.Program.ReadU16(code, frame.Pc + 2)]
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLoadFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat(
                    [int](code[frame.Pc + 1]),
                    program.FloatConstants[Bytecode.Program.ReadU16(code, frame.Pc + 2)]
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLoadBool
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool([int](code[frame.Pc + 1]), [int](code[frame.Pc + 2]) != 0);
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpLoadString
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetString(
                    [int](code[frame.Pc + 1]),
                    program.StringConstants[Bytecode.Program.ReadU16(code, frame.Pc + 2)]
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLoadChar
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetChar(
                    [int](code[frame.Pc + 1]),
                    [char](program.IntConstants[Bytecode.Program.ReadU16(code, frame.Pc + 2)])
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpMove
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.CopyValue([int](code[frame.Pc + 1]), [int](code[frame.Pc + 2]));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpAddInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int dst = [int](code[frame.Pc + 1]);
                int lhs = [int](code[frame.Pc + 2]);
                int rhs = [int](code[frame.Pc + 3]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                kinds[dst] = [int](Bytecode.ValueKind.Int);
                intRegisters[dst] = intRegisters[lhs] + intRegisters[rhs];
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpSubInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int dst = [int](code[frame.Pc + 1]);
                int lhs = [int](code[frame.Pc + 2]);
                int rhs = [int](code[frame.Pc + 3]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                kinds[dst] = [int](Bytecode.ValueKind.Int);
                intRegisters[dst] = intRegisters[lhs] - intRegisters[rhs];
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpMulInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) * frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpDivInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) / frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpAddFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) + frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpSubFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) - frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpMulFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) * frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpDivFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) / frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpNegInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt([int](code[frame.Pc + 1]), -frame.GetInt([int](code[frame.Pc + 2])));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpNegFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetFloat([int](code[frame.Pc + 1]), -frame.GetFloat([int](code[frame.Pc + 2])));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpEq
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool([int](code[frame.Pc + 1]), frame.ValueEquals([int](code[frame.Pc + 2]), [int](code[frame.Pc + 3])));
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpNe
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool([int](code[frame.Pc + 1]), !frame.ValueEquals([int](code[frame.Pc + 2]), [int](code[frame.Pc + 3])));
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLtInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) < frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLeInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) <= frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpGtInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) > frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpGeInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) >= frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLtFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) < frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpLeFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) <= frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpGtFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) > frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpGeFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool(
                    [int](code[frame.Pc + 1]),
                    frame.GetFloat([int](code[frame.Pc + 2])) >= frame.GetFloat([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpNotBool
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool([int](code[frame.Pc + 1]), !frame.GetBool([int](code[frame.Pc + 2])));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpBitAndInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) & frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpBitOrInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) | frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpBitXorInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) ^ frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpShlInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) << frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpShrInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt(
                    [int](code[frame.Pc + 1]),
                    frame.GetInt([int](code[frame.Pc + 2])) >> frame.GetInt([int](code[frame.Pc + 3]))
                );
                frame.Pc = frame.Pc + 4;
                Jump LoopStart;
            }

            Record OpBitNotInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt([int](code[frame.Pc + 1]), ~frame.GetInt([int](code[frame.Pc + 2])));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpIntToString
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetString([int](code[frame.Pc + 1]), [string](frame.GetInt([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpBoolToString
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetString([int](code[frame.Pc + 1]), [string](frame.GetBool([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpCharToString
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetString([int](code[frame.Pc + 1]), [string](frame.GetChar([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpStringToInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt([int](code[frame.Pc + 1]), [int](frame.GetString([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpStringToBool
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetBool([int](code[frame.Pc + 1]), [bool](frame.GetString([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpCharToInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetInt([int](code[frame.Pc + 1]), [int](frame.GetChar([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpIntToChar
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetChar([int](code[frame.Pc + 1]), [char](frame.GetInt([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpStringToChar
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.SetChar([int](code[frame.Pc + 1]), [char](frame.GetString([int](code[frame.Pc + 2]))));
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpJump
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 1);
                Jump LoopStart;
            }

            Record OpJumpIfFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                bool[] boolRegisters = frame.BoolRegisters;
                int cond = [int](code[frame.Pc + 1]);
                If (kinds[cond] != [int](Bytecode.ValueKind.Bool))
                {
                    Throw "Expected bool register";
                }
                If (!boolRegisters[cond])
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 2);
                }
                Else
                {
                    frame.Pc = frame.Pc + 4;
                }
                Jump LoopStart;
            }

            Record OpJumpIfTrue
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                bool[] boolRegisters = frame.BoolRegisters;
                int cond = [int](code[frame.Pc + 1]);
                If (kinds[cond] != [int](Bytecode.ValueKind.Bool))
                {
                    Throw "Expected bool register";
                }
                If (boolRegisters[cond])
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 2);
                }
                Else
                {
                    frame.Pc = frame.Pc + 4;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntLtFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] < intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntLeFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] <= intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntGtFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] > intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntGeFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] >= intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntEqFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] == intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpJumpIfIntNeFalse
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int lhs = [int](code[frame.Pc + 1]);
                int rhs = [int](code[frame.Pc + 2]);
                If (kinds[lhs] != [int](Bytecode.ValueKind.Int) || kinds[rhs] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int registers";
                }
                If (!(intRegisters[lhs] != intRegisters[rhs]))
                {
                    frame.Pc = Bytecode.Program.ReadU16(code, frame.Pc + 3);
                }
                Else
                {
                    frame.Pc = frame.Pc + 5;
                }
                Jump LoopStart;
            }

            Record OpIncInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int reg = [int](code[frame.Pc + 1]);
                If (kinds[reg] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int register";
                }
                intRegisters[reg] = intRegisters[reg] + 1;
                frame.Pc = frame.Pc + 2;
                Jump LoopStart;
            }

            Record OpDecInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int reg = [int](code[frame.Pc + 1]);
                If (kinds[reg] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int register";
                }
                intRegisters[reg] = intRegisters[reg] - 1;
                frame.Pc = frame.Pc + 2;
                Jump LoopStart;
            }

            Record OpIntToFloat
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                float[] floatRegisters = frame.FloatRegisters;
                int dst = [int](code[frame.Pc + 1]);
                int src = [int](code[frame.Pc + 2]);
                If (kinds[src] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Expected int register";
                }
                kinds[dst] = [int](Bytecode.ValueKind.Float);
                floatRegisters[dst] = [float](intRegisters[src]);
                frame.Pc = frame.Pc + 3;
                Jump LoopStart;
            }

            Record OpFloatToInt
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                float[] floatRegisters = frame.FloatRegisters;
