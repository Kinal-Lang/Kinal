            Record OpIsType
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int dst = [int](code[frame.Pc + 1]);
                int src = [int](code[frame.Pc + 2]);
                int targetKind = [int](code[frame.Pc + 3]);
                int targetPayload = Bytecode.Program.ReadU16(code, frame.Pc + 4);
                bool result = false;

                result = Switch(targetKind)
                {
                    Case([int](Bytecode.IsTargetKind.Bool))   { frame.Kinds[src] == [int](Bytecode.ValueKind.Bool) }
                    Case([int](Bytecode.IsTargetKind.Char))   { frame.Kinds[src] == [int](Bytecode.ValueKind.Char) }
                    Case([int](Bytecode.IsTargetKind.Int))    { frame.Kinds[src] == [int](Bytecode.ValueKind.Int) }
                    Case([int](Bytecode.IsTargetKind.Float))  { frame.Kinds[src] == [int](Bytecode.ValueKind.Float) }
                    Case([int](Bytecode.IsTargetKind.String)) { frame.Kinds[src] == [int](Bytecode.ValueKind.String) }
                    Case([int](Bytecode.IsTargetKind.Type))
                    {
                        frame.Kinds[src] == [int](Bytecode.ValueKind.Object) &&
                        ctx.ObjectIsType(frame.IntRegisters[src], targetPayload)
                    }
                    Case(default) { false }
                };

