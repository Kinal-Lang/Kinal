                Context.VMValue targetValue = ctx.ObjectGetValue(handle, 0);
                Context.VMValue envValue = ctx.ObjectGetValue(handle, 1);
                int encoded = targetValue.IntValue;
                int envHandle = -1;

                If (encoded < 0)
