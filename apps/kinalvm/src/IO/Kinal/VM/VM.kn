            Record OpLoopIntGtDec
            {
                Context.FunctionFrame frame = ctx.CurrentFrame();
                byte[] code = frame.FnInfo.Code;
                int[] kinds = frame.Kinds;
                int[] intRegisters = frame.IntRegisters;
                int counterReg = [int](code[frame.Pc + 1]);
                int limitReg = [int](code[frame.Pc + 2]);
                int counterValue;
                int limitValue;
                If (kinds[counterReg] != [int](Bytecode.ValueKind.Int) || kinds[limitReg] != [int](Bytecode.ValueKind.Int))
                {
                    Throw "Superloop requires int registers";
                }
                counterValue = intRegisters[counterReg];
                limitValue = intRegisters[limitReg];
                While (counterValue > limitValue)
                {
