Unit IO.UI;

Public Class Component
{
    Protected string _Text;
    Protected int _X;
    Protected int _Y;
    Protected int _Width;
    Protected int _Height;
    Protected byte* _Handle;
    Protected Color _BackColor;
    Protected Color _ForeColor;
    Protected Font _Font;
    Protected byte* _NativeBrush;
    Protected byte* _NativeFont;
    Protected byte* _NativeProc;
    Protected Window _Owner;
    Protected Event[] _Events;

    Public Constructor(string text = "", int x = 0, int y = 0, int width = 120, int height = 24)
    {
        _Text = text;
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _NativeProc = null;
        _Owner = default;
        _Events = {};
    }

    Public Property string Text
    {
        Get
        {
            Return _Text;
        }
        Set
        {
            _Text = value;
            If (Handle != null)
            {
                __UIHost.SetComponentText(This, value);
            }
        }
    }

    Public Property int X
    {
        Get
        {
            Return _X;
        }
        Set
        {
            _X = value;
            If (Handle != null)
            {
                __UIHost.UpdateComponentBounds(This);
            }
        }
    }

    Public Property int Y
    {
        Get
        {
            Return _Y;
        }
        Set
        {
            _Y = value;
            If (Handle != null)
            {
                __UIHost.UpdateComponentBounds(This);
            }
        }
    }

    Public Property int Width
    {
        Get
        {
            Return _Width;
        }
        Set
        {
            _Width = value;
            If (Handle != null)
            {
                __UIHost.UpdateComponentBounds(This);
            }
        }
    }

    Public Property int Height
    {
        Get
        {
            Return _Height;
        }
        Set
        {
            _Height = value;
            If (Handle != null)
            {
                __UIHost.UpdateComponentBounds(This);
            }
        }
    }

    Public Property Color BackColor
    {
        Get
        {
            Return _BackColor;
        }
        Set
        {
            _BackColor = value;
            __UIHost.ApplyComponentStyle(This);
        }
    }

    Public Property Color ForeColor
    {
        Get
        {
            Return _ForeColor;
        }
        Set
        {
            _ForeColor = value;
            __UIHost.ApplyComponentStyle(This);
        }
    }

    Public Property Font Font
    {
        Get
        {
            Return _Font;
        }
        Set
        {
            _Font = value;
            __UIHost.ApplyComponentStyle(This);
        }
    }

    Public Property byte* Handle
    {
        Get
        {
            Return _Handle;
        }
        Set
        {
            _Handle = value;
        }
    }

    Public Property byte* NativeBrush
    {
        Get
        {
            Return _NativeBrush;
        }
        Set
        {
            _NativeBrush = value;
        }
    }

    Public Property byte* NativeFont
    {
        Get
        {
            Return _NativeFont;
        }
        Set
        {
            _NativeFont = value;
        }
    }

    Public Property byte* NativeProc
    {
        Get
        {
            Return _NativeProc;
        }
        Set
        {
            _NativeProc = value;
        }
    }

    Public Property Window Owner
    {
        Get
        {
            Return _Owner;
        }
        Set
        {
            _Owner = value;
        }
    }

    Public Property Event[] Events
    {
        Get
        {
            Return _Events;
        }
        Set
        {
            _Events = value;
        }
    }

    Public Virtual Safe Function bool SupportsEvent(EventKind kind)
    {
        Return false;
    }

    Public Safe Function bool HasEvent(EventKind kind)
    {
        int i = 0;
        While (i < Events.Length())
        {
            If (Events[i].Kind == kind)
            {
                Return true;
            }
            i++;
        }
        Return false;
    }

    Public Virtual Safe Function string KindName()
    {
        Return "IO.UI.Component";
    }

    Public Trusted Function Color EffectiveBackColor()
    {
        If (BackColor != null)
        {
            Return BackColor;
        }
        If (Owner != null)
        {
            Return Owner.BackColor;
        }
        Return default;
    }

    Public Trusted Function Color EffectiveForeColor()
    {
        If (ForeColor != null)
        {
            Return ForeColor;
        }
        If (Owner != null)
        {
            Return Owner.ForeColor;
        }
        Return default;
    }

    Public Trusted Function Font EffectiveFont()
    {
        If (Font != null)
        {
            Return Font;
        }
        If (Owner != null)
        {
            Return Owner.Font;
        }
        Return default;
    }

    Public Trusted Function void __InternalSetText(string value)
    {
        _Text = value;
    }

    Public Function Component SetBackColor(Color color)
    {
        BackColor = color;
        Return This;
    }

    Public Function Component SetForeColor(Color color)
    {
        ForeColor = color;
        Return This;
    }

    Public Function Component SetFont(Font font)
    {
        Font = font;
        Return This;
    }

    Public Function Component AddEvent(Event event)
    {
        If (event == null)
        {
            Throw New IO.Error("IO.UI", "Event cannot be null");
        }
        If (!SupportsEvent(event.Kind))
        {
            __UI_ThrowUnsupportedEvent(KindName(), event.Kind);
        }
        Events = Events.Add(event);
        Return This;
    }

    Public Function Component RemoveEvent(Event event)
    {
        If (event == null)
        {
            Return This;
        }

        Event[] kept = {};
        int i = 0;
        While (i < Events.Length())
        {
            Event current = Events[i];
            If (current != event)
            {
                kept = kept.Add(current);
            }
            i++;
        }
        Events = kept;
        Return This;
    }

    Public Trusted Function void TriggerEvent(EventKind kind, usize wParam = 0, isize lParam = 0)
    {
        EventArgs args = New EventArgs(kind, wParam, lParam);
        int i = 0;
        While (i < Events.Length())
        {
            Event current = Events[i];
            If (current.Kind == kind)
            {
                current.Invoke(This, args);
            }
            i++;
        }
    }
}

Public Class Label By Component
{
    Public Constructor(string text, int x, int y, int width = 160, int height = 24)
    {
        _Text = text;
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.Label";
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        Handle = __UIHost.CreateLabelHandle(This, parent, instance);
        __UIHost.ApplyComponentStyle(This);
        Return Handle;
    }
}

Public Class Button By Component
{
    Private int _Id;

    Public Constructor(string text, int x, int y, int width = 120, int height = 28)
    {
        _Text = text;
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
        _Id = 0;
    }

    Public Property int Id
    {
        Get
        {
            Return _Id;
        }
        Set
        {
            _Id = value;
        }
    }

    Public Override Safe Function bool SupportsEvent(EventKind kind)
    {
        Return kind == EventKind.OnClick || kind == EventKind.OnMouseDown ||
               kind == EventKind.OnMouseMove || kind == EventKind.OnMouseUp;
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.Button";
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        If (Id == 0)
        {
            Id = __UIHost.AllocateControlId();
        }

        Handle = __UIHost.CreateButtonHandle(This, parent, instance);
        __UIHost.AttachButtonProc(This);
        __UIHost.ApplyComponentStyle(This);
        Return Handle;
    }

    Public Trusted Function void TriggerClick()
    {
        TriggerEvent(EventKind.OnClick, [usize](Id), 0);
    }
}

