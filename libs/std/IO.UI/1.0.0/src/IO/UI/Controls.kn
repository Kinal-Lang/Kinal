    Public Override Safe Function bool SupportsEvent(EventKind kind)
    {
        Return kind == EventKind.OnTextChanged || kind == EventKind.OnFocus ||
               kind == EventKind.OnBlur || kind == EventKind.OnKeyDown || kind == EventKind.OnKeyUp;
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.Input";
