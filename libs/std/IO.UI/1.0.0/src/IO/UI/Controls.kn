Public Class ComboBox By Component
{
    Private int _Id;
    Private string[] _Items;
    Private int _SelectedIndex;
    Private bool _Editable;

    Public Constructor(int x, int y, int width = 160, int height = 200)
    {
        _Text = "";
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
        _Id = 0;
        _Items = {};
        _SelectedIndex = -1;
        _Editable = false;
    }

    Public Property int Id
    {
        Get
        {
            Return _Id;
        }
        Set
        {
            _Id = value;
        }
    }

    Public Property string[] Items
    {
        Get
