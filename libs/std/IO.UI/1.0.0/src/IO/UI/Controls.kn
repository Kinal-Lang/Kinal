        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
        _Id = 0;
        _Multiline = false;
        _ReadOnly = false;
        _Password = false;
        _MaxLength = 0;
        _PlaceholderText = "";
    }

    Public Property int Id
    {
        Get
