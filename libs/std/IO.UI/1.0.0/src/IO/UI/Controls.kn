    {
        Password = password;
        Return This;
    }

    Public Function Input SetMaxLength(int maxLength)
    {
        MaxLength = maxLength;
        Return This;
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        If (Id == 0)
        {
            Id = __UIHost.AllocateControlId();
        }
        Handle = __UIHost.CreateInputHandle(This, parent, instance);
        __UIHost.ApplyComponentStyle(This);
        Return Handle;
    }
}

