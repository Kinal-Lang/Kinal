            Return _Items;
        }
        Set
        {
            _Items = value;
        }
    }

    Public Property int SelectedIndex
    {
        Get
        {
            Return _SelectedIndex;
        }
        Set
        {
            _SelectedIndex = value;
            If (Handle != null)
            {
                __UIHost.SetComboBoxSelectedIndex(This, value);
            }
        }
    }

    Public Property bool Editable
    {
        Get
        {
            Return _Editable;
        }
        Set
        {
            _Editable = value;
        }
    }

    Public Function ComboBox AddItem(string item)
    {
        Items = Items.Add(item);
        If (Handle != null)
        {
            __UIHost.ComboBoxAddItem(This, item);
        }
        Return This;
