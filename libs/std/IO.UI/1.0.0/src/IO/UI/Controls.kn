    Public Function ComboBox ClearItems()
    {
        Items = {};
        SelectedIndex = -1;
        If (Handle != null)
        {
            __UIHost.ComboBoxClear(This);
        }
        Return This;
    }

    Public Override Safe Function bool SupportsEvent(EventKind kind)
    {
        Return kind == EventKind.OnSelectedChanged || kind == EventKind.OnFocus || kind == EventKind.OnBlur;
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.ComboBox";
    }

    Public Trusted Function void __InternalSetSelectedIndex(int index)
    {
        _SelectedIndex = index;
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        If (Id == 0)
        {
            Id = __UIHost.AllocateControlId();
        }
        Handle = __UIHost.CreateComboBoxHandle(This, parent, instance);
        __UIHost.ApplyComponentStyle(This);
        Return Handle;
    }
}

Public Class ProgressBar By Component
{
    Private int _Minimum;
    Private int _Maximum;
    Private int _Value;
    Private int _Step;

    Public Constructor(int x, int y, int width = 200, int height = 24)
    {
        _Text = "";
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
        _Minimum = 0;
        _Maximum = 100;
        _Value = 0;
        _Step = 10;
    }

    Public Property int Minimum
    {
        Get
        {
            Return _Minimum;
        }
        Set
        {
            _Minimum = value;
            If (Handle != null)
            {
                __UIHost.SetProgressBarRange(This);
            }
        }
    }

    Public Property int Maximum
    {
        Get
        {
            Return _Maximum;
        }
        Set
        {
            _Maximum = value;
            If (Handle != null)
            {
                __UIHost.SetProgressBarRange(This);
            }
        }
    }

    Public Property int Value
    {
        Get
        {
            Return _Value;
        }
        Set
        {
            _Value = value;
            If (Handle != null)
            {
                __UIHost.SetProgressBarValue(This);
            }
        }
    }

    Public Property int Step
    {
        Get
        {
            Return _Step;
        }
        Set
        {
            _Step = value;
            If (Handle != null)
            {
                __UIHost.SetProgressBarStep(This);
            }
        }
    }

    Public Trusted Function void PerformStep()
    {
        If (Handle != null)
        {
            __UIHost.ProgressBarStepIt(This);
        }
        _Value = _Value + Step;
        If (_Value > Maximum)
        {
            _Value = Maximum;
        }
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.ProgressBar";
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        Handle = __UIHost.CreateProgressBarHandle(This, parent, instance);
        Return Handle;
    }
}

Public Class GroupBox By Component
{
    Private Component[] _Children;

    Public Constructor(string text, int x, int y, int width = 300, int height = 200)
    {
        _Text = text;
        _X = x;
        _Y = y;
        _Width = width;
        _Height = height;
        _Handle = null;
        _BackColor = default;
        _ForeColor = default;
        _Font = default;
        _NativeBrush = null;
        _NativeFont = null;
        _Owner = default;
        _Events = {};
        _Children = {};
    }

    Public Property Component[] Children
    {
        Get
        {
            Return _Children;
        }
        Set
        {
            _Children = value;
        }
    }

    Public Function GroupBox Add(Component child)
    {
        If (child == null)
        {
            Throw New IO.Error("IO.UI", "Child component cannot be null");
        }
        Children = Children.Add(child);
        Return This;
    }

    Public Override Safe Function string KindName()
    {
        Return "IO.UI.GroupBox";
    }

    Public Trusted Function byte* CreateNative(byte* parent, byte* instance)
    {
        Handle = __UIHost.CreateGroupBoxHandle(This, parent, instance);
        __UIHost.AttachGroupBoxProc(This);
        __UIHost.ApplyComponentStyle(This);

        int i = 0;
        While (i < Children.Length())
        {
            Component child = Children[i];
            child.Owner = Owner;
            __UIHost.CreateChildNative(child, Handle, instance);
            i++;
        }
        Return Handle;
    }
}
