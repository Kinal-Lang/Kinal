# =========================================
# Kinal .gitignore
# =========================================

# -----------------------------------------
# Build outputs / generic output dirs
# -----------------------------------------
/out/
/build/
/dist/
/release/
/debug/
/bin/
/obj/
/artifacts/

build-*/
cmake-build-*/
debug-*/
release-*/

.cmake/
CMakeFiles/
CMakeCache.txt
compile_commands.json
cmake_install.cmake
install_manifest.txt
Makefile

# -----------------------------------------
# Kinal cache / temp
# -----------------------------------------
/.kinal-cache/
/.cache/
/temp/
/tmp/
tmp_*/
*.tmp
*.temp
*.bak
*.klib

# -----------------------------------------
# Compiled / binary / object files
# -----------------------------------------
*.exe
*.out
*.app
*.obj
*.o
*.lo
*.pdb
*.idb
*.ilk
*.exp
*.lib
*.a
*.dll
*.so
*.dylib
*.wasm

# LLVM / compiler intermediate outputs
*.bc
*.ll
*.s
*.asm
*.i
*.ii

# Debug / symbols / profiling / coverage
*.dSYM/
*.su
*.gcno
*.gcda
*.profraw
*.profdata
coverage/

# -----------------------------------------
# Archives / packages / large distributables
# -----------------------------------------
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.tar.xz
*.txz
*.tar.bz2
*.tbz2
*.tar.zst
*.xz
*.gz
*.bz2
*.zst

# VS Code extension packages
*.vsix

# -----------------------------------------
# Toolchain bootstrap caches (kept outside the repository layout)
# -----------------------------------------
.toolchains/

# -----------------------------------------
# Node.js / npm / pnpm / yarn
# -----------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn-cache/
.yarnrc.yml
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------
# Kinal LSP
# -----------------------------------------
/apps/kinal-lsp/server/build/
/apps/kinal-lsp/server/build-*/
/apps/kinal-lsp/server/out/
/apps/kinal-lsp/server/dist/
/apps/kinal-lsp/server/node_modules/

# -----------------------------------------
# Python
# -----------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
.pyre/
.tox/
.nox/
.venv/
venv/
ENV/
env/
pip-wheel-metadata/

# -----------------------------------------
# Rust / Cargo (if used by tooling)
# -----------------------------------------
target/

# -----------------------------------------
# Java / Kotlin / Gradle (if ever used by tooling)
# -----------------------------------------
.gradle/
*.class

# -----------------------------------------
# IDE / editor
# -----------------------------------------
.vs/
.idea/
*.swp
*.swo
*~
*.orig
*.rej
*.sublime-workspace
*.sublime-project

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/tasks.json.example
!.vscode/launch.json.example

# VS Code test dirs
.vscode-test/
.vscode-test-web/

# -----------------------------------------
# Visual Studio / MSBuild
# -----------------------------------------
*.user
*.rsuser
*.suo
*.opendb
*.VC.db
*.VC.VC.opendb
*.sln.docstates
*.aps
*.ncb

# -----------------------------------------
# Logs
# -----------------------------------------
*.log
build-*.log
logs/
log/

# -----------------------------------------
# Environment / local machine config
# -----------------------------------------
.env
.env.local
.env.*.local
*.local

# -----------------------------------------
# OS files
# -----------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.directory

# -----------------------------------------
# Generated docs / site outputs (uncomment if needed)
# -----------------------------------------
# /docs/build/
# /site/
# /.sass-cache/

# -----------------------------------------
# Test outputs / snapshots
# -----------------------------------------
*.snap
test-results/
reports/

# -----------------------------------------
# Security / secrets
# -----------------------------------------
*.key
*.pem
*.pfx
*.p12

# -----------------------------------------
# Keep placeholders if you use empty dirs
# -----------------------------------------
!.gitkeep
