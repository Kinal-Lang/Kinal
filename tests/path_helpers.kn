Unit Tests.PathHelpers;

Get Console By IO.Console;
Get IO.Path;

Static Function int Main()
{
    string p2 = IO.Path.Join("src", "managed");
    string p3 = IO.Path.Join3("src", "managed", "html");
    string p4 = IO.Path.Join4("src", "managed", "html", "index.html");
    string parent = IO.Path.Parent(p4);
    string ensured = IO.Path.EnsureTrailingSeparator(IO.Path.Parent(p2));

    Console.PrintLine(IO.Path.FileName(parent) == "html");
    Console.PrintLine(IO.Path.FileName(p4));
    Console.PrintLine(IO.Path.Stem(p4));
    Console.PrintLine(IO.Path.HasExtension(p4));
    Console.PrintLine(IO.Path.IsRelative(p4));
    Console.PrintLine(ensured != parent);
    Console.PrintLine(IO.Path.FileName(IO.Path.Parent(ensured)) == "src");
    Console.PrintLine(IO.Path.BaseName("archive.tar.gz"));
    Console.PrintLine(IO.Path.ChangeExtension("archive.tar.gz", "txt"));
    string normalized = IO.Path.Normalize("a//b///c");
    Console.PrintLine(IO.Path.FileName(normalized) == "c");
    Console.PrintLine(IO.Path.FileName(p3) == "html");
    Return 0;
}
