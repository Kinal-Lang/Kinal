Unit Tests.PathPosix;

Get Console By IO.Console;
Get IO.Path;

Static Function int Main()
{
    Console.PrintLine(IO.Path.Join("usr", "local"));
    Console.PrintLine(IO.Path.Join3("usr", "local", "bin"));
    Console.PrintLine(IO.Path.IsAbsolute("/usr/local"));
    Console.PrintLine(IO.Path.IsAbsolute("usr/local"));
    Console.PrintLine(IO.Path.Normalize("usr//local///bin"));
    Console.PrintLine(IO.Path.FileName("/home/user/file.txt"));
    Console.PrintLine(IO.Path.Parent("/home/user/file.txt"));
    Return 0;
}
