Unit Tests.AnonEvent;

Get IO.UI;

Static Function int Main()
{
    IO.UI.Window window = New IO.UI.Window("Anon Event Test", 480, 320);

    IO.UI.Button button = New IO.UI.Button("Click", 20, 20, 120, 28);
    button.AddEvent(New IO.UI.Event(IO.UI.EventKind.OnClick, Function void(){
        button.Text = "Clicked!";
    }));
    window.Add(button);

    Return window.Run();
}




