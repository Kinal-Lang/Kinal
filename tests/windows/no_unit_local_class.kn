Get UI By IO.UI;

Class MainWindow
{
    Private UI.Window window;
    Private UI.Label label;
    Private UI.Button button;

    Public Constructor()
    {
        window= New UI.Window("Kinal Window", 480, 320);
        window.SetBackColor(New UI.Color(32, 32, 40));
        window.SetForeColor(UI.Color.White());
        window.SetFont(New UI.Font("Segoe UI", 18, UI.FontWeight.Normal));

        label= New UI.Label("Hello from Kinal UI", 20, 20, 220, 24);
        label.SetForeColor(UI.Color.White());
        label.SetFont(New UI.Font("Segoe UI", 20, UI.FontWeight.Bold));

        button= New UI.Button("Click", 20, 60, 120, 28);
        button.SetBackColor(UI.Color.Blue());
        button.SetForeColor(UI.Color.White());
        button.AddEvent(New UI.Event(UI.EventKind.OnClick, Function void()
        {
            button.Text= "Clicked!";
        }
        ));

        window.Add(label);
        window.Add(button);
    }

    Public Function int Run()
    {
        Return 0;
    }
}

Static Function int Main()
{
    MainWindow mainWindow= New MainWindow();
    Return mainWindow.Run();
}
