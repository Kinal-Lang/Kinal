Unit Tests.FfiObj;

Get Console By IO.Console;

Extern Function int kn_native_add(int a, int b) By C;
Extern Function int kn_native_mul(int a, int b) By C;
Extern Function string kn_native_hello() By C;

Trusted Static Function int Main()
{
    Console.PrintLine(kn_native_add(2, 3));
    Console.PrintLine(kn_native_mul(4, 5));
    Console.PrintLine(kn_native_hello());
    Return 0;
}
