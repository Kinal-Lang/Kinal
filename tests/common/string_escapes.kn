Unit Tests.StringEscapes;

Get Console By IO.Console;

Static Safe Function int Main(string args[])
{
    Console.PrintLine("line1\nline2");
    Console.PrintLine("quote:\"");
    Console.PrintLine("slash:\\");
    Console.PrintLine("tick:'");
    Console.PrintLine([string]([int]("\b"[0])));
    Console.PrintLine([string]([int]('\n')));
    Return 0;
}
