Unit Tests.Freestanding.CoreMemory;

Get IO.Memory;
Get IO.Panic;

Trusted Static Function void KMain()
{
    byte src= 0x41;
    byte dst= 0;

    IO.Memory.Copy(&dst, &src, 1);
    If (IO.Memory.Compare(&src, &dst, 1)!= 0)
    {
        IO.Panic.Abort();
    }

    IO.Memory.Zero(&dst, 1);
    If (dst!= 0)
    {
        IO.Panic.Abort();
    }

    While (true)
    {
    }
}
