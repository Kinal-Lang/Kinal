Unit Tests.StdlibWebCompile;

Get IO.Web;

Public Class DemoController
{
    [IO.Web.Route("/hello")] Public Trusted Static Function void Hello(IO.Web.Context ctx)
    {
        ctx.Response.Text("hello");
    }

    [IO.Web.Route("/ping", IO.Web.HttpMethod.POST)] Public Trusted Static Function void Ping(IO.Web.Context ctx)
    {
        ctx.Response.Text(ctx.Request.MethodText+ ":"+[string](ctx.Request.ContentLength)+ ":"+ ctx.Request.BodyText());
    }
}

Trusted Static Function int Main()
{
    IO.Web.Server server= New IO.Web.Server(18080);
    server.EnableDebug().EnableLiveReload().UseStatic("/static", "tests").RefreshRoutes().UseRoutes();
    Return 0;
}
