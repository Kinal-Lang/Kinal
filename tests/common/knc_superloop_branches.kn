Unit Tests.KncSuperloopBranches;

Get Console By IO.Console;

Static Function int Main()
{
    int a = 0;
    For (; a == 0; a++)
    {
    }
    Console.PrintLine(a);

    int b = 0;
    For (; b != 5; b++)
    {
    }
    Console.PrintLine(b);

    int c = 0;
    For (; c == 0; c--)
    {
    }
    Console.PrintLine(c);

    int d = 5;
    For (; d != 0; d--)
    {
    }
    Console.PrintLine(d);

    Return 0;
}
