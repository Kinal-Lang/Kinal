Unit Tests.AsyncCall;

Get Console By IO.Console;
Get IO.Async;

Static Async Function int Step(int value)
{
    Return value + 1;
}

Static Async Function int Compute()
{
    int first = Await Step(40);
    int second = Await Step(first);
    Return second;
}

Static Function int Main()
{
    int value = IO.Async.Run(Compute());
    Console.PrintLine(value);
    Return 0;
}