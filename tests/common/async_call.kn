Unit Tests.AsyncCall;

Get Console By IO.Console;
Get IO.Async;

StaticAsyncFunction int Step(int value)
{
    Return value+ 1;
}

StaticAsyncFunction int Compute()
{
    int first= AwaitStep(40);
    int second= AwaitStep(first);
    Return second;
}

Static Function int Main()
{
    int value= IO.Async.Run(Compute());
    Console.PrintLine(value);
    Return 0;
}
