Unit Tests.SwitchMatcher;

Get Console By IO.Console;

Static Safe Function int Score(int value)
{
    Switch (value)
    {
        Case(1)
        {
            Console.PrintLine("one");
        }
        Case(2)
        {
            Console.PrintLine("two");
        }
        Case(
        default)
        {
            Console.PrintLine("other");
        }
    }

    Return Switch (value)
    {
        Case(1)
        {
            10;
        }
        Case(2)
        {
            default;
        }
        Case(
        default)
        {
            30;
        }
    };
}

Static Safe Function int Main(string args[])
{
    Console.PrintLine([string](Score(1)));
    Console.PrintLine([string](Score(2)));
    Console.PrintLine([string](Score(9)));

    int zero=
    default;
    Console.PrintLine([string](zero));
    Return 0;
}
