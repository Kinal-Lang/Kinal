// Test 1: New [type](value) cast syntax with pointers
fn any_to_int(x: Any): int
{
    let i=[int](x);
    return i;
}

fn int_to_ptr(x: int): void* {
    return[void*](x);
}

fn test_cast()
{
    let a=(123, "test");
    let i=[int](a);
    println("Cast to int: {0}", i);

    let p=[void*](i);
    println("Cast to pointer: {0}", p);

    let back=[int](p);
    println("Cast back to int: {0}", back);
}

// Test 2: Array size with expressions
fn array_with_expr(len: int)
{
    let buffer: u8[len+ 1];
    let buffer2: u16[len* 2];

    println("Array size: {0}", buffer.len);
}

// Test 3: Global variables with Static and Const modifiers
Static int counter= 0;
Static Const int MAX_SIZE= 1024;
Const float PI= 3.14159;

fn increment_global()
{
    counter= counter+ 1;
    println("Counter: {0}", counter);
}

fn test_globals()
{
    println("MAX_SIZE: {0}", MAX_SIZE);
    println("PI: {0}", PI);

    increment_global();
    increment_global();
}

fn main()
{
    test_cast();
    array_with_expr(10);
    test_globals();
}
