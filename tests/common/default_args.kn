Unit Tests.DefaultArgs;

Get Console By IO.Console;

Class Pair
{
    Private int left;
    Private int right;

    Public Safe Function Pair(int left= 1, int right= 2)
    {
        This.left= left;
        This.right= right;
    }

    Public Safe Function int Sum()
    {
        Return This.left+ This.right;
    }
}

Static Safe Function int Add(int p1= 1, int p2= 2)
{
    Return p1+ p2;
}

Static Safe Function int Main(string args[])
{
    Var fn= Add;
    Pair a= New Pair();
    Pair b= New Pair(
    default, 10);

    Console.PrintLine([string](Add()));
    Console.PrintLine([string](Add(
    default,
    default)));
    Console.PrintLine([string](Add(100,
    default)));
    Console.PrintLine([string](Add(p2= 1, p1=
    default)));
    Console.PrintLine([string](fn(
    default, 5)));
    Console.PrintLine([string](fn(p2= 1, p1=
    default)));
    Console.PrintLine([string](a.Sum()));
    Console.PrintLine([string](b.Sum()));
    Return 0;
}
