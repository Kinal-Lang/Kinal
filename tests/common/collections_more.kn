Unit Tests.CollectionsMore;

Get Console By IO.Console;

Static Function int Main()
{
    list l= list.Create();
    l.Add("a");
    l.Add("b");
    Console.PrintLine([string](l.Peek()));
    Console.PrintLine(l.IndexOf("a"));
    Console.PrintLine(l.IndexOf("z"));

    dict d= dict.Create();
    d.Set("name", "kinal");
    Console.PrintLine([string](d.TryFetch("name", "none")));
    Console.PrintLine([string](d.TryFetch("missing", "none")));
    Return 0;
}
