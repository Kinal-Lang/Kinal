Unit Tests.IOError;
Get Console By IO.Console;

Static Function int Main()
{
    IO.Error e= New IO.Error("Title", "Message");
    Console.PrintLine(e.Title);
    Console.PrintLine(e.Message);

    Try
    {
        Throw e;
    }
    Catch (string msg)
    {
        Console.PrintLine(msg);
    }

    Try
    {
        Throw New IO.Error("T", "M");
    }
    Catch (IO.Error err)
    {
        Console.PrintLine(err.Title);
        Console.PrintLine(err.Message);
    }

    Return 0;
}
