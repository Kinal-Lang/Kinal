Unit Tests.StructEnum;

Get Console By IO.Console;

Enum Irq By u8 {
    Timer = 0,
    Keyboard = 1
}

Struct Pair By Align(8) {
    int a;
    int b;
}

Static Safe Function int Main(string args[]) {
    Pair p;
    p.a = 10;
    p.b = 32;
    Irq v = Irq.Timer;
    If (p.a + p.b == 42 && v == Irq.Timer) {
        Console.PrintLine("ok");
    } Else {
        Console.PrintLine("bad");
    }
    Return 0;
}

