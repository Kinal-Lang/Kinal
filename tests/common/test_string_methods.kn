Unit Tests.StringMethods;

Get Console By IO.Console;

// Test string .Length() method
Function void test_string_length() {
    Var text = "hello";
    Var len = text.Length();
    Console.PrintLine("String length: {0}", len);
    
    Var literal_len = "world".Length();
    Console.PrintLine("Literal length: {0}", literal_len);
}

// Test string indexing with [index]
Function void test_string_index() {
    Var text = "hello";
    Var first_char = text[0];
    Console.PrintLine("First char: {0}", first_char);
    
    Var second_char = text[1];
    Console.PrintLine("Second char: {0}", second_char);
    
    // Test with literal
    Var literal_char = "abc"[2];
    Console.PrintLine("Literal char [2]: {0}", literal_char);
}

// Test string .Index() method
Function void test_string_index_method() {
    Var text = "hello";
    Var ch = text.Index(0);
    Console.PrintLine("Index(0): {0}", ch);
    
    Var ch2 = text.Index(4);
    Console.PrintLine("Index(4): {0}", ch2);
    
    Var literal_ch = "test".Index(1);
    Console.PrintLine("Literal Index(1): {0}", literal_ch);
}

// Test combining Length and Index
Function void test_string_operations() {
    Var str = "Kinal";
    Console.PrintLine("String: {0}", str);
    Console.PrintLine("Length: {0}", str.Length());
    Console.PrintLine("First: {0}", str[0]);
    Console.PrintLine("Last: {0}", str[str.Length() - 1]);
    
    Console.PrintLine("Using Index method:");
    Console.PrintLine("Index(0): {0}", str.Index(0));
    Console.PrintLine("Index(5): {0}", str.Index(5));
}

Static Function int Main() {
    test_string_length();
    Console.PrintLine("");
    
    test_string_index();
    Console.PrintLine("");
    
    test_string_index_method();
    Console.PrintLine("");
    
    test_string_operations();
    
    Return 0;
}

