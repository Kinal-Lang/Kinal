Unit Tests.AnyMethods;

Get Console By IO.Console;

Class Box
{
    Public int Value;

    Public Constructor(int value)
    {
        Value= value;
    }
}

Static Function int Main()
{
    int i= 42;
    string s= null;
    Box b= New Box(7);
    any a= null;

    Console.PrintLine(i.ToString());
    Console.PrintLine(i.TypeName());
    Console.PrintLine(i.Equals(42));
    Console.PrintLine(i.IsNull());
    Console.PrintLine(s.IsNull());
    Console.PrintLine(b.TypeName());
    Console.PrintLine(b.IsNull());
    Console.PrintLine(a.IsNull());
    Return 0;
}
