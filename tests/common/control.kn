Unit Tests.Control;

Get Console By IO.Console;

Static Function int Main()
{
    Var sum= 0;
    Var i= 0;
    While (i< 5)
    {
        sum= sum+ i;
        i= i+ 1;
    }

    If (sum== 10)
    {
        Console.PrintLine("ok");
    }
    Else
    {
        Console.PrintLine("bad");
    }

    Var j= 0;
    For (; j< 3;)
    {
        j= j+ 1;
    }

    Return 0;
}
