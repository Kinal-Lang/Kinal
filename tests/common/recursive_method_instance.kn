Unit Tests.RecursionInstance;

Get Console By IO.Console;

Class Math
{
    Public Function int SumTo(int n)
    {
        If (n<= 0)
        {
            Return 0;
        }

        Return n+ SumTo(n- 1);
    }
}

Safe Static Function int Main()
{
    Math math= New Math();
    Console.PrintLine(math.SumTo(5));
    Return 0;
}
