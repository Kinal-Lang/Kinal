Unit Tests.BuiltinMetaAttrs;

Get Console By IO.Console;
Get IO.Meta;

[Docs("Builtin docs")][Deprecated("Use Next")][Since("2.1.0")][Example("Console.PrintLine(\"demo\");")][Experimental("Subject to change")] Static Function int Main()
{
    dict docs= IO.Meta.Find(Main, "Docs");
    dict deprecated= IO.Meta.Find(Main, "Deprecated");
    dict since= IO.Meta.Find(Main, "Since");
    dict example= IO.Meta.Find(Main, "Example");
    dict experimental= IO.Meta.Find(Main, "Experimental");

    Console.PrintLine([string](docs.Fetch("arg.text")));
    Console.PrintLine([string](deprecated.Fetch("arg.message")));
    Console.PrintLine([string](since.Fetch("arg.version")));
    Console.PrintLine([string](example.Fetch("arg.code")));
    Console.PrintLine([string](experimental.Fetch("arg.message")));
    Return 0;
}
