Unit MiniLang.Lexer;

Get Console By IO.Console;
Get T By MiniLang.Token;

Class Lexer
{
    Private string Source;
    Private int Position;

    Public Function Lexer(string source)
    {
        This.Source= source;
        This.Position= 0;
    }

    Public Function T.Token NextAlias()
    {
        Return New T.Token(T.TokenType.Literal, "alias");
    }
}

Static Function int Main(string args[])
{
    Lexer lx= New Lexer("abc");
    Console.PrintLine(lx.NextAlias().Value);
    Return 0;
}
