Unit Tests.DictLiteral;

Get Console By IO.Console;

Static Function int Main()
{
    dict d= {
        "name": "kinal", "n": 123
    };
    dict empty= {
    };
    Console.PrintLine([string](d.Fetch("name")));
    Console.PrintLine([int](d.Fetch("n")));
    Console.PrintLine(empty.Count());
    Return 0;
}
