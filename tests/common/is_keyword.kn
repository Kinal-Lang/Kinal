Unit Tests.IsKeyword;

Get Console By IO.Console;

Interface INode
{
    Function int Id();
}

Class Animal
{
}

Class Dog By Animal
{
}

Class Node By INode
{
    Public Function int Id()
    {
        Return 7;
    }
}

Static Safe Function int Main(string[] args)
{
    Animal a= New Dog();
    INode n= New Node();
    string s= "ok";
    Animal none= null;
    Console.PrintLine(a Is Animal);
    Console.PrintLine(a Is Dog);
    Console.PrintLine(a Is Node);
    Console.PrintLine(n Is INode);
    Console.PrintLine(n Is Node);
    Console.PrintLine(s Is string);
    Console.PrintLine(1 Is float);
    Console.PrintLine(none Is Animal);
    Return 0;
}
