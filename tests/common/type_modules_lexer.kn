Unit MiniLang.Lexer;

Get Console By IO.Console;
Get MiniLang.Token;

Class Lexer
{
    Public Function MiniLang.Token.Token NextQualified()
    {
        Return New MiniLang.Token.Token("full");
    }
}

Static Function int Main(string args[])
{
    Lexer lx= New Lexer();
    Console.PrintLine(lx.NextQualified().Value);
    Return 0;
}
