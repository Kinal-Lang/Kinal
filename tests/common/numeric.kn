Unit Tests.Numeric;

Get Console By IO.Console;

Static Function int Main()
{
    i32 a= 40;
    u64 b= 2;
    int sum= a+ 2;
    float f= 1.5;
    float g= f+ 2.5;
    If (sum== 42&& g== 4.0&& b== 2)
    {
        Console.PrintLine("ok");
    }
    Else
    {
        Console.PrintLine("bad");
    }
    Return 0;
}
