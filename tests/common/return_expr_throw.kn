Unit Tests.ReturnExprThrow;

Get IO.Console;

Class Demo
{
    Public Static Function string Fail()
    {
        Throw "bad";
    }

    Public Static Function string Pick(int value)
    {
        Return Switch (value)
        {
            Case(1)
            {
                "ok"
            }
            Case(
            default)
            {
                Demo.Fail()
            }
        };
    }
}

Safe Static Function int Main()
{
    IO.Console.PrintLine(Demo.Pick(0));
    Return 0;
}
