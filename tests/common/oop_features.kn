Unit Tests.OOP;

Get Console By IO.Console;

Abstract Class BaseType
{
    Protected int value;

    Public Safe Constructor(int start)
    {
        This.value= start;
    }

    Public Abstract Safe Function int Value();
    Public Virtual Safe Function string Kind()
    {
        Return "base";
    }
}

Class Derived By BaseType
{
    Public Safe Constructor(int start)
    {
        This.value= start+ 1;
    }

    Public Override Safe Function int Value()
    {
        Return This.value;
    }

    Public Override Safe Function string Kind()
    {
        Return Base.Kind()+ ":derived";
    }
}

Sealed Class Final By Derived
{
    Public Safe Constructor(int start)
    {
        This.value= start+ 2;
    }
}

Static Safe Function int Main(string args[])
{
    BaseType b= New Derived(1);
    If (b.Value()== 2)
    {
        Console.PrintLine(b.Kind());
    }
    Else
    {
        Console.PrintLine("bad");
    }
    Return 0;
}
