Unit Tests.KncTimeFile;

Get Console By IO.Console;
Get IO.File;
Get IO.Time;

Static Function int Main()
{
    string path = "out/test/knc_vm_time_file_tmp.txt";
    string missing = "out/test/knc_vm_time_file_missing.txt";

    IO.File.DeleteIfExists(path);
    IO.File.DeleteIfExists(missing);

    int tick = IO.Time.GetTick();
    IO.Time.Sleep(0);
    int nano = IO.Time.GetNanoTick();

    Console.PrintLine("ok");
    Console.PrintLine(IO.File.WriteAllText(path, "alpha"));
    Console.PrintLine(IO.File.Exists(path));
    Console.PrintLine(IO.File.ReadAllText(path));
    Console.PrintLine(IO.File.ReadOrDefault(missing, "fallback"));
    Console.PrintLine(IO.File.AppendLine(path, "beta"));
    Console.PrintLine(IO.File.ReadFirstLine(path));
    Console.PrintLine(IO.File.DeleteIfExists(path));
    Console.PrintLine(IO.File.Exists(path));
    Return 0;
}
