Unit App.Main;

Get Console By IO.Console;

Class BaseType {
    Public Virtual Safe Function string Msg() {
        Return "base";
    }
}

Class Derived By BaseType {
    Public Override Safe Function string Msg() {
        Return "derived";
    }
}

Static Safe Function int Main(string args[]) {
    BaseType b = New Derived();
    Console.PrintLine(b.Msg());
    Return 0;
}

