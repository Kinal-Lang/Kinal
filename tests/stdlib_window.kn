Unit Tests.StdlibWindow;

Get IO.UI;

Function void OnClick(IO.Type.Object.Class sender, IO.UI.EventArgs args)
{
}

Function void OnShown(IO.Type.Object.Class sender, IO.UI.EventArgs args)
{
}

Static Function int Main()
{
    IO.UI.Window window = New IO.UI.Window("Kinal Window", 480, 320);
    window.SetBackColor(New IO.UI.Color(32, 32, 40));
    window.SetForeColor(IO.UI.Color.White());
    window.SetFont(New IO.UI.Font("Segoe UI", 18, IO.UI.FontWeight.Normal));
    window.AddEvent(New IO.UI.Event(IO.UI.EventKind.OnShown, OnShown));

    IO.UI.Label label = New IO.UI.Label("Hello from Kinal UI", 20, 20, 220, 24);
    label.SetForeColor(IO.UI.Color.White());
    label.SetFont(New IO.UI.Font("Segoe UI", 20, IO.UI.FontWeight.Bold));
    window.Add(label);

    IO.UI.Button button = New IO.UI.Button("Click", 20, 60, 120, 28);
    button.SetBackColor(IO.UI.Color.Blue());
    button.SetForeColor(IO.UI.Color.White());
    button.AddEvent(New IO.UI.Event(IO.UI.EventKind.OnClick, OnClick));
    window.Add(button);

    Return window.Run();
}
